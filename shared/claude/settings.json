{
  "env": {
    "DISABLE_ZOXIDE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          },
          {
            "type": "command",
            "command": "bash ~/assets/dotfiles/shared/scripts/tmux/claude-notify.sh stop",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/assets/dotfiles/shared/scripts/tmux/claude-notify.sh clear",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Sosumi.aiff"
          },
          {
            "type": "command",
            "command": "bash ~/assets/dotfiles/shared/scripts/tmux/claude-notify.sh notify",
            "async": true
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "medium"
}
